<!DOCTYPE html>
<html>

<head>
    <title>Naye Pankh Foundation</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('partials/navbar') %>

    <section class="hero">

        <h1><span class="sticker">🕊️</span>Giving Wings To Dreams</h1>

        <p>
            Together we can create a brighter future
            for every child and community.
        </p>

        <a href="/volunteer" class="btn">
            Become A Volunteer
        </a>

    </section>

    <section class="about">

        <h2><span class="sticker">🌱</span>About Naye Pankh Foundation</h2>

        <p>
            Naye Pankh Foundation works towards education,
            empowerment, and community development.
        </p>

    </section>

    <section class="stats">

        <div class="card">
            <h2>500+</h2>
            <p>🤝 Volunteers</p>
        </div>

        <div class="card">
            <h2>1000+</h2>
            <p>✨ Lives Impacted</p>
        </div>

        <div class="card">
            <h2>50+</h2>
            <p>📅 Events Conducted</p>
        </div>

    </section>

    <%- include('partials/footer') %>

</body>

</html>
